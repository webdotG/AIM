{
  "name": "dream-journal-backend",
  "version": "1.0.0",
  "description": "Life Graph — psychological profile through graph analysis of dreams, memories, thoughts, plans, and actions",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node dist/db/migrate.js",
    "seed": "node dist/db/seed.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.unit.config.ts --passWithNoTests",
    "test:integration": "TZ=UTC NODE_ENV=test jest --config jest.integration.config.ts --runInBand",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "test:watch": "jest --config jest.integration.config.ts --watch",
    "test:coverage": "jest --config jest.integration.config.ts --coverage",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --config jest.integration.config.ts --runInBand --no-coverage",
    "migrate:test": "node scripts/migrate-test-db.js",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d",
    "db:test:down": "docker compose -f docker-compose.test.yml down",
    "db:test:reset": "npm run db:test:down && npm run db:test:up",
    "db:test:setup": "psql -U postgres -c 'CREATE DATABASE dream_journal_test;'",
    "db:test:drop": "psql -U postgres -c 'DROP DATABASE IF EXISTS dream_journal_test;'",
    "swagger-serve": "node -e \"const y=require('yaml');const f=require('fs');const s=y.parse(f.readFileSync('swagger.yaml','utf8'));console.log('Paths:',Object.keys(s.paths).length);console.log('Ops:',Object.values(s.paths).reduce((a,p)=>a+Object.keys(p).length,0));\""
  },
  "keywords": [
    "journal",
    "dreams",
    "anonymous",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/winston": "^2.4.4",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.1",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.7",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
